---
// HomeHero.astro - Version sin efectos giratorios
import { getSiteInfo } from '../lib/wordpress';
const siteInfo = await getSiteInfo();
const title = siteInfo?.title || 'Vinyl Station Radio';
const description =
  siteInfo?.description ||
  "Emisora online dedicada a la diversidad musical, el talento emergente y la cultura del vinilo.";
---

<section class="home-hero">
  <div class="hero-content">
    <img src="/images/logos/logo vinylstation.png" alt="VinylStation Logo" class="hero-main-logo" />
    <h1>{title}</h1>
    <p>{description}</p>
    <div class="cta-buttons">
      <button id="listen-live-btn" class="btn primary-btn">Escuchar en vivo</button>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Auto-play del reproductor
    document.getElementById('listen-live-btn').addEventListener('click', function() {
      const audioPlayer = document.getElementById('radio-stream');
      if (audioPlayer) audioPlayer.play().catch(() => {});
    });
  });
</script>

<style>
.home-hero {
  position: relative;
  padding: 7rem 2rem;
  text-align: center;
  background: linear-gradient(135deg, #1a1a1a 0%, #232323 100%);
  overflow: hidden;
  min-height: 400px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.hero-content {
  position: relative;
  z-index: 2;
}

/* Logo principal del hero SIN animaciones */
.hero-main-logo {
  width: 80px;
  height: 80px;
  object-fit: contain;
  margin-bottom: 1.5rem;
  filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
  transition: all 0.3s ease;
}

.hero-main-logo:hover {
  transform: scale(1.05);
}

/* Tamaños responsivos */
@media (min-width: 768px) {
  .hero-main-logo {
    width: 120px;
    height: 120px;
    margin-bottom: 2rem;
  }
}

/* Estilos para el título y descripción */
.home-hero h1 {
  font-size: 4rem;
  margin: 0 0 1rem;
  font-weight: 700;
  color: var(--title-color);
}

.home-hero p {
  font-size: 1.5rem;
  color: #888;
  margin: 0 0 3rem;
  line-height: 1.6;
}

/* Botón CTA */
.cta-buttons {
  margin-top: 2rem;
}

.primary-btn {
  background: var(--title-color);
  color: var(--color-bg);
  padding: 1rem 2rem;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 1.1rem;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.primary-btn:hover {
  background: #a8935e;
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(197, 173, 123, 0.4);
}

/* Responsive */
@media (max-width: 768px) {
  .home-hero {
    padding: 5rem 1rem 4rem;
  }
  
  .home-hero h1 {
    font-size: 2.5rem;
  }
  
  .home-hero p {
    font-size: 1.2rem;
    margin: 0 0 2rem;
  }
  
  .hero-main-logo {
    width: 60px;
    height: 60px;
    margin-bottom: 1rem;
  }
}

@media (max-width: 480px) {
  .home-hero h1 {
    font-size: 2rem;
  }
  
  .home-hero p {
    font-size: 1rem;
  }
}
</style>
