      if (!iframe) return;
      
      console.log('Inicializando widget de programación...');
      
      // Mostrar loading inicialmente
      if (loadingOverlay) {
        loadingOverlay.style.display = 'flex';
        loadingOverlay.style.opacity = '1';
      }
      
      if (fallback) {
        fallback.style.display = 'none';
      }
      
      // Timeout más largo para detectar si el iframe no carga
      const loadTimeout = setTimeout(() => {
        console.warn('Widget de programación no pudo cargar en 12 segundos, mostrando fallback');
        hideLoadingShowFallback();
      }, 12000); // 12 segundos timeout
      
      // Función para ocultar loading y mostrar fallback
      function hideLoadingShowFallback() {
        if (loadingOverlay) {
          loadingOverlay.style.opacity = '0';
          setTimeout(() => {
            loadingOverlay.style.display = 'none';
          }, 300);
        }
        
        if (fallback) {
          fallback.style.display = 'block';
          setTimeout(() => {
            fallback.style.opacity = '1';
          }, 100);
        }
        
        if (wrapper) {
          wrapper.classList.add('widget-error');
        }
      }
      
      // Función para ocultar loading y mostrar iframe
      function hideLoadingShowIframe() {
        if (loadingOverlay) {
          loadingOverlay.style.opacity = '0';
          setTimeout(() => {
            loadingOverlay.style.display = 'none';
          }, 300);
        }
        
        if (iframe) {
          iframe.style.opacity = '0';
          iframe.style.display = 'block';
          setTimeout(() => {
            iframe.style.opacity = '1';
          }, 100);
        }
        
        if (wrapper) {
          wrapper.classList.add('widget-loaded');
        }
      }
      
      // Evento cuando el iframe carga exitosamente
      iframe.onload = () => {
        console.log('Widget de programación: evento onload disparado');
        clearTimeout(loadTimeout);
        
        // Verificar si el contenido cargó correctamente
        setTimeout(() => {
          try {
            // Intentar acceder al contenido del iframe
            const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
            if (iframeDoc && iframeDoc.body && iframeDoc.body.innerHTML.trim()) {
              console.log('Widget de programación cargado exitosamente con contenido');
              hideLoadingShowIframe();
            } else {
              console.warn('Widget cargó pero sin contenido visible');
              hideLoadingShowFallback();
            }
          } catch (e) {
            // Error de CORS es normal para iframes externos
            console.log('Widget de programación cargado (CORS normal - esto es esperado)');
            hideLoadingShowIframe();
          }
        }, 1500); // Dar más tiempo para que el contenido interno del iframe cargue
      };
      
      // Evento si el iframe falla al cargar
      iframe.onerror = () => {
        console.error('Error cargando widget de programación');
        clearTimeout(loadTimeout);
        hideLoadingShowFallback();
      };
      
      // Timeout adicional para contenido interno del iframe
      setTimeout(() => {
        if (loadingOverlay && loadingOverlay.style.display !== 'none') {
          console.log('Timeout secundario - assumiendo que el widget cargó correctamente');
          clearTimeout(loadTimeout);
          hideLoadingShowIframe();
        }
      }, 8000); // 8 segundos - tiempo razonable para que cargue el contenido
      
      // Botón de reintentar en el fallback
      const retryButton = document.createElement('button');
      retryButton.className = 'retry-button';
      retryButton.textContent = 'Reintentar carga';
      retryButton.style.display = 'none';
      
      retryButton.addEventListener('click', () => {
        console.log('Reintentando carga del widget...');
        if (fallback) fallback.style.display = 'none';
        if (loadingOverlay) {
          loadingOverlay.style.display = 'flex';
          loadingOverlay.style.opacity = '1';
        }
        if (wrapper) {
          wrapper.classList.remove('widget-error', 'widget-loaded');
        }
        
        // Recargar iframe
        const currentSrc = iframe.src;
        iframe.src = '';
        setTimeout(() => {
          iframe.src = currentSrc;
        }, 500);
        
        // Reiniciar timeout
        setTimeout(() => {
          if (loadingOverlay && loadingOverlay.style.display !== 'none') {
            hideLoadingShowFallback();
          }
        }, 12000);
      });
      
      if (fallback) {
        fallback.appendChild(retryButton);
      }
    }
    
    // Inicializar widget de programación con manejo de errores
    try {
      initScheduleWidget();
    } catch (error) {
      console.error('Error inicializando widget de programación:', error);
    }
    
    // Efecto de brillo en el indicador de "EN VIVO"
    const liveIndicator = document.querySelector('.live-status-indicator');
    if (liveIndicator) {
      setInterval(() => {
        liveIndicator.style.transform = 'scale(1.05)';
        setTimeout(() => {
          liveIndicator.style.transform = 'scale(1)';
        }, 200);
      }, 5000);
    }
  });
</script>

