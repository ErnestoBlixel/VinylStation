    // === SISTEMA MEJORADO DE METADATA Y CARÁTULAS ===
    class EnhancedMetadataSystem {
      constructor(radioPlayer) {
        this.radioPlayer = radioPlayer;
        
        // URLs de APIs múltiples para mayor confiabilidad
        this.apis = {
          zeno: 'https://api.zeno.fm/mounts/metadata/subscribe/4g7qxnxrloluv',
          zenoAlternative: 'https://public.radio-co.com/stations/sb8d5179e9/status',
          icecast: 'https://stream.zeno.fm/4g7qxnxrloluv.xspf'
        };
        
