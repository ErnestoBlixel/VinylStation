      async fetchDeezerArtwork(artist, title) {
        try {
          const searchQuery = encodeURIComponent(`${artist} ${title}`);
          const url = `https://api.deezer.com/search?q=${searchQuery}&limit=1&output=jsonp&callback=deezerCallback`;
          
          return new Promise((resolve) => {
            // Crear callback global temporal
            window.deezerCallback = (data) => {
              if (data && data.data && data.data.length > 0) {
                const track = data.data[0];
                const artwork = track.album?.cover_medium || track.album?.cover_big;
                resolve(artwork);
              } else {
                resolve(null);
              }
              delete window.deezerCallback;
            };
            
            // Crear script tag para JSONP
            const script = document.createElement('script');
            script.src = url;
            script.onerror = () => resolve(null);
            document.head.appendChild(script);
            
            // Limpiar script después
            setTimeout(() => {
              if (script.parentNode) {
                script.parentNode.removeChild(script);
              }
              if (window.deezerCallback) {
                delete window.deezerCallback;
                resolve(null);
              }
            }, 5000);
          });
        } catch (error) {
          return null;
        }
      }
      
