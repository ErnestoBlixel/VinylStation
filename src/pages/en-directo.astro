      async processMetadata(metadata) {
        if (!metadata || !metadata.title) return;
        
        // Evitar actualizaciones duplicadas
        if (this.currentTrack && this.currentTrack.title === metadata.title) {
          return;
        }
        
        console.log('🎵 Procesando nueva metadata:', metadata);
        
        // Parsear título y artista
        const parsed = this.parseTrackInfo(metadata.title, metadata.artist);
        
        // Crear objeto de track completo
        const trackInfo = {
          ...parsed,
          originalTitle: metadata.title,
          listeners: metadata.listeners || null,
          source: metadata.source || 'Desconocido',
          timestamp: new Date()
        };
        
        this.currentTrack = trackInfo;
        
        // Actualizar UI inmediatamente
        this.updatePlayerUI(trackInfo);
        
        // Buscar carátula en background
        this.fetchArtworkAsync(trackInfo.artist, trackInfo.title);
        
        // Emitir evento
        window.dispatchEvent(new CustomEvent('enhancedMetadataUpdated', {
          detail: trackInfo
        }));
      }
      
      parseTrackInfo(title, artist = null) {
        if (!title) {
          return {
            artist: 'VinylStation Radio',
            title: 'Transmitiendo en directo desde Fuensalida'
          };
        }
        
        // Si ya tenemos artista separado, usarlo
        if (artist && artist !== 'Artista Desconocido') {
          return {
            artist: this.cleanString(artist),
            title: this.cleanString(title)
          };
        }
        
        // Patrones mejorados de separación
        const separators = [
          { pattern: ' - ', priority: 1 },
          { pattern: ' – ', priority: 1 },
          { pattern: ' — ', priority: 1 },
          { pattern: ' | ', priority: 2 },
          { pattern: ' · ', priority: 3 },
          { pattern: ': ', priority: 4 },
          { pattern: ' / ', priority: 5 }
        ];
        
        // Intentar separar con cada patrón
        for (const sep of separators) {
          if (title.includes(sep.pattern)) {
            const parts = title.split(sep.pattern);
            if (parts.length >= 2 && parts[0].trim() && parts[1].trim()) {
              return {
                artist: this.cleanString(parts[0]),
                title: this.cleanString(parts.slice(1).join(sep.pattern))
              };
            }
          }
        }
        
        // Intentar detectar formato \"Artista\" - Título
        const quotedArtistMatch = title.match(/^[\"']([^\"']+)[\"']\s*[-–—]\s*(.+)$/);
        if (quotedArtistMatch) {
          return {
            artist: this.cleanString(quotedArtistMatch[1]),
            title: this.cleanString(quotedArtistMatch[2])
          };
        }
        
        // Si no se puede separar, usar todo como título
        return {
          artist: 'VinylStation Radio',
          title: this.cleanString(title)
        };
      }
      
      cleanString(str) {
        if (!str) return '';
        
        return str
          .trim()
          .replace(/\s+/g, ' ')
          .replace(/[\"']/g, '')
          .replace(/\([^)]*\)/g, '')
          .replace(/\[[^\]]*\]/g, '')
          .replace(/\s*[-–—]\s*$/g, '')
          .trim();
      }
      
      updatePlayerUI(trackInfo) {
