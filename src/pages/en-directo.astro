---
// Página "En Directo" - Reproductor principal de radio
import MainLayout from '../layouts/MainLayout.astro';
import { getSiteInfo } from '../lib/wordpress';

// Obtener información del sitio para SEO
let siteInfo = null;
let hasError = false;

try {
  siteInfo = await getSiteInfo();
} catch (error) {
  hasError = true;
  console.error('Error obteniendo información del sitio:', error);
}

// SEO específico para la página En Directo
const pageTitle = hasError ? 'En Directo - VinylStation' : `En Directo - ${siteInfo?.title || 'VinylStation Radio'}`;
const pageDescription = hasError ? 'Escucha VinylStation Radio en directo' : `Escucha ${siteInfo?.title || 'VinylStation Radio'} en directo. Música 24/7 desde Fuensalida, Toledo.`;
---

<MainLayout title={pageTitle} description={pageDescription}>
  <div class="live-page">
    <!-- Hero principal con reproductor destacado -->
    <section class="live-hero">
      <div class="container">
        <div class="live-hero-content">
          <div class="live-status-indicator">
            <span class="live-dot"></span>
            <span class="live-text">EN VIVO</span>
          </div>
          
          <h1>VinylStation Radio</h1>
          <p class="live-subtitle">Conecta con la mejor música desde Fuensalida, Toledo</p>
          
          <!-- Reproductor principal -->
          <div class="main-radio-player">
            <audio id="main-radio-stream" preload="none" data-stream-url="https://stream.zeno.fm/4g7qxnxrloluv"></audio>
            
            <div class="player-container">
              <div class="album-art">
                <img src="/images/logos/logo vinylstation.png" alt="VinylStation Radio" id="album-artwork">
                <div class="vinyl-animation"></div>
              </div>
              
              <div class="player-info">
                <div class="now-playing">
                  <h3 id="track-title">VinylStation Radio</h3>
                  <p id="track-artist">En directo desde Fuensalida</p>
                  <div class="song-progress">
                    <span id="song-duration">• En Vivo</span>
                  </div>
                </div>
                
                <div class="player-controls">
                  <button id="main-play-pause" class="main-play-button" aria-label="Reproducir/Pausar">
                    <svg id="main-play-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polygon points="5,3 19,12 5,21"></polygon>
                    </svg>
                    <svg id="main-pause-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                      <rect x="6" y="4" width="4" height="16"></rect>
                      <rect x="14" y="4" width="4" height="16"></rect>
                    </svg>
                  </button>
                  
                  <div class="progress-bar">
                    <div class="progress-fill"></div>
                  </div>
                  
                  <div class="volume-control">
                    <button id="main-volume-toggle" class="volume-button" aria-label="Silenciar/Activar sonido">
                      <svg id="main-volume-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="11,5 6,9 2,9 2,15 6,15 11,19"></polygon>
                        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                      </svg>
                      <svg id="main-volume-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                        <polygon points="11,5 6,9 2,9 2,15 6,15 11,19"></polygon>
                        <line x1="23" y1="9" x2="17" y2="15"></line>
                        <line x1="17" y1="9" x2="23" y2="15"></line>
                      </svg>
                    </button>
                    <input type="range" id="main-volume-slider" class="volume-slider" min="0" max="1" step="0.05" value="0.7">
                  </div>
                </div>
                
                <div class="status-bar">
                  <span id="main-status-text">Preparado para reproducir</span>
                  <div id="main-loading-indicator" class="loading-indicator" style="display: none;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Programación Semanal Widget -->
    <section class="weekly-schedule">
      <div class="container">
        <div class="section-header">
          <h2>Programación Semanal</h2>
          <p>Descubre qué programas están <strong>sonando ahora</strong> y qué viene después en <strong>VinylStation Radio</strong>.</p>
        </div>
        
        <div class="schedule-container">
          <div class="schedule-wrapper">
            <div class="loading-overlay">
              <div class="loading-spinner"></div>
              <p class="loading-text">Cargando programación...</p>
            </div>
            <iframe 
              class="schedule-iframe"
              src="https://4g7qxnxrloluv.pl.zeno.fm/embed/weekly-program"
              loading="lazy"
              title="Programación Semanal VinylStation Radio">
            </iframe>
          </div>
          
          <div class="schedule-fallback">
            <div class="fallback-content">
              <div class="fallback-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                  <rect x="7" y="7" width="3" height="9"></rect>
                  <rect x="14" y="7" width="3" height="5"></rect>
                </svg>
              </div>
              <h3>Programación VinylStation Radio</h3>
              <div class="fallback-schedule">
                <div class="schedule-item">
                  <span class="schedule-time">📻 Lunes a Viernes</span>
                  <span class="schedule-desc">Programación musical variada</span>
                </div>
                <div class="schedule-item">
                  <span class="schedule-time">🎵 Fines de semana</span>
                  <span class="schedule-desc">Especiales de vinilo y música emergente</span>
                </div>
                <div class="schedule-item">
                  <span class="schedule-time">📱 24/7</span>
                  <span class="schedule-desc">La mejor música desde Fuensalida, Toledo</span>
                </div>
              </div>
              <a href="/programas" class="fallback-button">Ver Todos los Programas</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Información adicional -->
    <section class="live-info">
      <div class="container">
        <div class="info-grid">
          <div class="info-card">
            <div class="info-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path>
                <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                <line x1="12" y1="19" x2="12" y2="23"></line>
                <line x1="8" y1="23" x2="16" y2="23"></line>
              </svg>
            </div>
            <h3>Transmisión en Vivo</h3>
            <p>Escucha nuestra programación 24/7 con la mejor calidad de audio desde nuestros estudios en Fuensalida.</p>
          </div>
          
          <div class="info-card">
            <div class="info-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polygon points="10,8 16,12 10,16"></polygon>
              </svg>
            </div>
            <h3>Música Continua</h3>
            <p>Disfruta de una selección curada de música vinilo, clásicos y artistas emergentes sin interrupciones.</p>
          </div>
          
          <div class="info-card">
            <div class="info-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </div>
            <h3>Programación Especializada</h3>
            <p>Programas dedicados a diferentes géneros musicales y espacios para artistas locales y emergentes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Enlaces rápidos -->
    <section class="quick-links">
      <div class="container">
        <h2>Explora más VinylStation</h2>
        <div class="links-grid">
          <a href="/programas" class="link-card">
            <div class="link-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                <rect x="7" y="7" width="3" height="9"></rect>
                <rect x="14" y="7" width="3" height="5"></rect>
              </svg>
            </div>
            <h3>Programas</h3>
            <p>Descubre nuestra programación completa</p>
          </a>
          
          <a href="/noticias" class="link-card">
            <div class="link-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"></path>
                <path d="M18 14h-8"></path>
                <path d="M15 18h-5"></path>
                <path d="M10 6h8v4h-8V6Z"></path>
              </svg>
            </div>
            <h3>Noticias</h3>
            <p>Mantente informado con las últimas noticias</p>
          </a>
          
          <a href="/contacto" class="link-card">
            <div class="link-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <h3>Contacto</h3>
            <p>Ponte en contacto con nosotros</p>
          </a>
          
          <a href="/" class="link-card">
            <div class="link-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9,22 9,12 15,12 15,22"></polyline>
              </svg>
            </div>
            <h3>Inicio</h3>
            <p>Vuelve a la página principal</p>
          </a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // === REPRODUCTOR PRINCIPAL DE RADIO CON ZENO API ===
    class MainRadioPlayer {
      constructor() {
        this.audio = document.getElementById('main-radio-stream');
        this.playPauseBtn = document.getElementById('main-play-pause');
        this.playIcon = document.getElementById('main-play-icon');
        this.pauseIcon = document.getElementById('main-pause-icon');
        this.statusText = document.getElementById('main-status-text');
        this.loadingIndicator = document.getElementById('main-loading-indicator');
        this.volumeToggle = document.getElementById('main-volume-toggle');
        this.volumeOnIcon = document.getElementById('main-volume-on');
        this.volumeOffIcon = document.getElementById('main-volume-off');
        this.volumeSlider = document.getElementById('main-volume-slider');
        this.trackTitle = document.getElementById('track-title');
        this.trackArtist = document.getElementById('track-artist');
        this.albumArt = document.getElementById('album-artwork');
        this.vinylAnimation = document.querySelector('.vinyl-animation');
        this.progressFill = document.querySelector('.progress-fill');
        this.songDuration = document.getElementById('song-duration');
        
        this.isPlaying = false;
        this.isLoading = false;
        this.retryCount = 0;
        this.maxRetries = 3;
        
        // Configuración de Zeno API
        this.zenoApiUrl = 'https://api.zeno.fm/mounts/metadata/subscribe/4g7qxnxrloluv';
        this.metadataUpdateInterval = null;
        this.lastTrackId = null;
        this.songHistory = [];
        
        this.init();
      }
      
      init() {
        if (!this.audio) return;
        
        const streamUrl = this.audio.getAttribute('data-stream-url');
        this.audio.src = streamUrl;
        this.audio.volume = parseFloat(this.volumeSlider?.value || 0.7);
        this.audio.preload = 'none';
        
        this.bindEvents();
        this.startProgressAnimation();
        
        // Iniciar sistema de metadata de Zeno
        this.startMetadataFetching();
        
        // Intentar obtener artwork desde APIs externas
        this.initArtworkSystem();
      }
      
      bindEvents() {
        // Controles principales
        this.playPauseBtn?.addEventListener('click', () => this.togglePlayPause());
        this.volumeToggle?.addEventListener('click', () => this.toggleMute());
        this.volumeSlider?.addEventListener('input', (e) => this.updateVolume(e.target.value));
        
        // Eventos del audio
        this.audio?.addEventListener('loadstart', () => this.setLoading(true));
        this.audio?.addEventListener('canplay', () => this.setLoading(false));
        this.audio?.addEventListener('play', () => this.setPlaying(true));
        this.audio?.addEventListener('pause', () => this.setPlaying(false));
        this.audio?.addEventListener('error', () => this.handleError());
        this.audio?.addEventListener('stalled', () => this.handleStalled());
        this.audio?.addEventListener('waiting', () => this.setLoading(true));
        this.audio?.addEventListener('playing', () => this.setLoading(false));
        this.audio?.addEventListener('ended', () => this.handleEnded());
        
        // Detectar cambios de conexión
        window.addEventListener('online', () => this.handleConnectionRestore());
        window.addEventListener('offline', () => this.handleConnectionLoss());
      }
      
      async togglePlayPause() {
        if (!this.audio) return;
        
        try {
          if (this.isPlaying) {
            this.audio.pause();
          } else {
            this.setLoading(true);
            this.retryCount = 0;
            await this.audio.play();
          }
        } catch (error) {
          console.error('Error reproduciendo:', error);
          this.handleError();
        }
      }
      
      setPlaying(playing) {
        this.isPlaying = playing;
        
        if (playing) {
          if (this.playIcon) this.playIcon.style.display = 'none';
          if (this.pauseIcon) this.pauseIcon.style.display = 'block';
          if (this.statusText) this.statusText.textContent = 'Transmitiendo en vivo';
          this.playPauseBtn?.classList.add('playing');
          this.vinylAnimation?.classList.add('spinning');
          this.albumArt?.classList.add('playing');
        } else {
          if (this.playIcon) this.playIcon.style.display = 'block';
          if (this.pauseIcon) this.pauseIcon.style.display = 'none';
          if (this.statusText) this.statusText.textContent = 'Pausado';
          this.playPauseBtn?.classList.remove('playing');
          this.vinylAnimation?.classList.remove('spinning');
          this.albumArt?.classList.remove('playing');
        }
      }
      
      setLoading(loading) {
        this.isLoading = loading;
        
        if (loading) {
          if (this.loadingIndicator) this.loadingIndicator.style.display = 'block';
          if (this.statusText) this.statusText.textContent = 'Conectando...';
          this.playPauseBtn?.classList.add('loading');
        } else {
          if (this.loadingIndicator) this.loadingIndicator.style.display = 'none';
          this.playPauseBtn?.classList.remove('loading');
          if (this.isPlaying && this.statusText) {
            this.statusText.textContent = 'Transmitiendo en vivo';
          }
        }
      }
      
      toggleMute() {
        if (!this.audio) return;
        this.audio.muted = !this.audio.muted;
        this.updateVolumeIcons();
      }
      
      updateVolume(value) {
        if (!this.audio) return;
        this.audio.volume = parseFloat(value);
        this.audio.muted = value == 0;
        this.updateVolumeIcons();
      }
      
      updateVolumeIcons() {
        const isMuted = this.audio.muted || this.audio.volume === 0;
        
        if (isMuted) {
          if (this.volumeOnIcon) this.volumeOnIcon.style.display = 'none';
          if (this.volumeOffIcon) this.volumeOffIcon.style.display = 'block';
        } else {
          if (this.volumeOnIcon) this.volumeOnIcon.style.display = 'block';
          if (this.volumeOffIcon) this.volumeOffIcon.style.display = 'none';
        }
      }
      
      async handleError() {
        this.setLoading(false);
        this.setPlaying(false);
        
        if (this.retryCount < this.maxRetries) {
          this.retryCount++;
          if (this.statusText) this.statusText.textContent = `Reintentando... (${this.retryCount}/${this.maxRetries})`;
          
          setTimeout(async () => {
            try {
              this.audio.load();
              if (this.retryCount <= this.maxRetries) {
                await this.audio.play();
              }
            } catch (error) {
              this.handleError();
            }
          }, 2000 * this.retryCount);
        } else {
          if (this.statusText) this.statusText.textContent = 'Error de conexión - Verifica tu conexión';
          this.retryCount = 0;
        }
      }
      
      handleStalled() {
        this.setLoading(true);
        if (this.statusText) this.statusText.textContent = 'Cargando stream...';
      }
      
      handleEnded() {
        // Para streams en vivo, si se termina, intentar reconectar
        setTimeout(() => {
          if (!this.isPlaying) {
            this.audio.load();
          }
        }, 1000);
      }
      
      handleConnectionLoss() {
        if (this.statusText) this.statusText.textContent = 'Sin conexión a internet';
        this.setPlaying(false);
      }
      
      handleConnectionRestore() {
        if (this.statusText) this.statusText.textContent = 'Conexión restaurada';
        this.retryCount = 0;
        setTimeout(() => {
          if (!this.isPlaying) {
            this.togglePlayPause();
          }
        }, 1000);
      }
      
      startProgressAnimation() {
        if (!this.progressFill) return;
        
        setInterval(() => {
          if (this.isPlaying && !this.isLoading) {
            // Animación de progreso simulada para stream en vivo
            const current = parseFloat(this.progressFill.style.width) || 0;
            const next = (current + 0.5) % 100;
            this.progressFill.style.width = `${next}%`;
          }
        }, 200);
      }
      
      // === MÉTODOS DE ZENO API ===
      
      startMetadataFetching() {
        this.fetchZenoMetadata();
        this.metadataUpdateInterval = setInterval(() => {
          this.fetchZenoMetadata();
        }, 10000); // Cada 10 segundos
      }
      
      async fetchZenoMetadata() {
        try {
          const response = await fetch(this.zenoApiUrl, {
            method: 'GET',
            headers: {
              'Accept': 'application/json',
              'Cache-Control': 'no-cache'
            }
          });
          
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }
          
          const data = await response.json();
          this.processZenoMetadata(data);
          
        } catch (error) {
          console.warn('Error obteniendo metadata de Zeno:', error);
          this.setFallbackMetadata();
        }
      }
      
      processZenoMetadata(data) {
        if (!data || !data.streamTitle) {
          this.setFallbackMetadata();
          return;
        }
        
        const streamTitle = data.streamTitle;
        const trackId = data.streamTitle + '_' + Date.now();
        
        // Evitar actualizaciones duplicadas
        if (this.lastTrackId === streamTitle) return;
        this.lastTrackId = streamTitle;
        
        // Parsear título - intentar separar artista y canción
        const { artist, title } = this.parseStreamTitle(streamTitle);
        
        // Actualizar UI
        this.updateNowPlayingInfo(artist, title, streamTitle);
        
        // Añadir a historial
        this.addToHistory(artist, title, streamTitle);
        
        // Buscar artwork
        this.fetchArtwork(artist, title);
        
        console.log('Metadata actualizada:', { artist, title, raw: streamTitle });
      }
      
      parseStreamTitle(streamTitle) {
        if (!streamTitle) {
          return { artist: 'VinylStation Radio', title: 'En directo desde Fuensalida' };
        }
        
        // Patrones comunes de separación
        const separators = [' - ', ' – ', ' — ', ' | ', ' · ', ': '];
        
        for (const separator of separators) {
          if (streamTitle.includes(separator)) {
            const parts = streamTitle.split(separator);
            if (parts.length >= 2) {
              return {
                artist: parts[0].trim(),
                title: parts.slice(1).join(separator).trim()
              };
            }
          }
        }
        
        // Si no se puede separar, usar todo como título
        return {
          artist: 'VinylStation Radio',
          title: streamTitle.trim()
        };
      }
      
      updateNowPlayingInfo(artist, title, rawTitle) {
        if (this.trackTitle) {
          this.trackTitle.textContent = title || 'Sin información';
          this.trackTitle.title = rawTitle; // Tooltip con texto completo
        }
        
        if (this.trackArtist) {
          this.trackArtist.textContent = artist || 'Artista desconocido';
        }
        
        if (this.songDuration) {
          this.songDuration.textContent = '• En Vivo';
        }
        
        // Animar cambio de canción
        this.animateTrackChange();
        
        // Mostrar notificación de cambio (opcional)
        this.showTrackChangeNotification(artist, title);
      }
      
      animateTrackChange() {
        [this.trackTitle, this.trackArtist].forEach(element => {
          if (element) {
            element.style.opacity = '0.5';
            element.style.transform = 'translateY(-5px)';
            
            setTimeout(() => {
              element.style.opacity = '1';
              element.style.transform = 'translateY(0)';
            }, 200);
          }
        });
      }
      
      showTrackChangeNotification(artist, title) {
        // Solo mostrar si no es la información por defecto
        if (artist === 'VinylStation Radio') return;
        
        // Crear notificación temporal
        const notification = document.createElement('div');
        notification.className = 'track-change-notification';
        notification.innerHTML = `
          <div class="notification-content">
            <span class="notification-title">Ahora suena</span>
            <span class="notification-track">${title}</span>
            <span class="notification-artist">por ${artist}</span>
          </div>
        `;
        
        document.body.appendChild(notification);
        
        // Animar entrada
        setTimeout(() => notification.classList.add('show'), 100);
        
        // Animar salida y eliminar
        setTimeout(() => {
          notification.classList.remove('show');
          setTimeout(() => {
            if (notification.parentNode) {
              notification.parentNode.removeChild(notification);
            }
          }, 300);
        }, 4000);
      }
      
      addToHistory(artist, title, rawTitle) {
        const historyItem = {
          artist,
          title,
          rawTitle,
          timestamp: new Date(),
          id: Date.now() + Math.random()
        };
        
        this.songHistory.unshift(historyItem);
        
        // Mantener solo las últimas 10 canciones
        if (this.songHistory.length > 10) {
          this.songHistory = this.songHistory.slice(0, 10);
        }
        
        // Emitir evento para posibles listeners externos
        window.dispatchEvent(new CustomEvent('trackChanged', {
          detail: historyItem
        }));
      }
      
      setFallbackMetadata() {
        this.updateNowPlayingInfo(
          'VinylStation Radio', 
          'Transmitiendo en directo desde Fuensalida', 
          'VinylStation Radio - En Vivo'
        );
      }
      
      // === SISTEMA DE ARTWORK ===
      
      initArtworkSystem() {
        // Configurar imagen por defecto
        this.defaultArtwork = '/images/logos/logo vinylstation.png';
        this.currentArtwork = this.defaultArtwork;
      }
      
      async fetchArtwork(artist, title) {
        if (!artist || !title || artist === 'VinylStation Radio') {
          this.setDefaultArtwork();
          return;
        }
        
        try {
          // Intentar Deezer API primero
          const deezerArtwork = await this.fetchDeezerArtwork(artist, title);
          if (deezerArtwork) {
            this.updateArtwork(deezerArtwork);
            return;
          }
          
          // Fallback a Last.fm si Deezer falla
          const lastfmArtwork = await this.fetchLastFmArtwork(artist, title);
          if (lastfmArtwork) {
