          const response = await fetch(`https://stream.zeno.fm/4g7qxnxrloluv`, {
            method: 'HEAD',
            signal: controller.signal
          });
          
          clearTimeout(timeoutId);
          
          const streamTitle = response.headers.get('icy-title') || 
                             response.headers.get('ice-title') ||
