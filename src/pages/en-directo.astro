      async fetchMetadata() {
        try {
          console.log('🔄 Obteniendo metadata mejorada...');
          
          // Intentar múltiples fuentes en paralelo
          const metadataPromises = [
            this.fetchZenoMetadata(),
            this.fetchIcecastMetadata(),
            this.fetchShoutcastMetadata()
          ];
          
          const results = await Promise.allSettled(metadataPromises);
          
          // Usar el primer resultado exitoso
          for (const result of results) {
            if (result.status === 'fulfilled' && result.value) {
              await this.processMetadata(result.value);
              this.retryCount = 0;
              return;
            }
          }
          
          this.handleMetadataFailure();
          
        } catch (error) {
          console.warn('❌ Error general obteniendo metadata:', error);
          this.handleMetadataFailure();
        }
      }
      
      async fetchZenoMetadata() {
